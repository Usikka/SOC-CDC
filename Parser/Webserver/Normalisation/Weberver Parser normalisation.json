{
  "version": 1,
  "name": "webserver_subindex",
  "rules": [
    {
      "type": "branch",
      "condition": "(host.name=='putlv3' or host.name=='pginvit-v3'or host.name=='newwebapps' or host.name=='dreamsweb')",
      "ifTrue": [
        {
          "type": "regex",
          "src": "line_text",
          "exp": [
            "\"(?<date>\\d{4}-\\d{2}-\\d{2})\\s(?<time>\\d{2}:\\d{2}:\\d{2})\\s(?<server_ip>\\S+)\\s(?<http_method>\\S+)\\s(?<cs_uri_stem>[^\\r\\n]+?\\.\\w+)\\s(?<cs_uri_query>-|\\S*)\\s+-\\s+(?<port>\\S+)\\s(?<user>\\S+)\\s(?<client_ip>\\S+)\\s(?<user_agent>.+?)\\s(?<ref_url>\\S+)\\s(?<status>\\S+)\\s(?<sc_substatus>\\S+)\\s(?<sc_win32_status>\\S+)\\s(?<time_taken>\\S+)\\s(?<requested_ip>\\S+)\""
