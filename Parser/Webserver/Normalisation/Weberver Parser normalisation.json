
{
  "version": 1,
  "name": "webserver",
  "rules": [
    {
      "type": "regex",
      "src": "line_text",
      "exp": [
        "(?<date>\\S+)\\s(?<time>\\S+)\\s(?<server_ip>\\S+)\\s(?<http_method>\\S+)\\s(?<url>\\S+)\\s(?<cs_uri_query>\\S+)\\s(?<port>\\S+)\\s(?<user>\\S+)\\s(?<client_ip>\\S+)\\s(?<webclient>\\S+)\\s(?<ref_url>\\S+)\\s(?<status>\\S+)\\s(?<sc_substatus>\\S+)\\s(?<sc_win32_status>\\S+)\\s(?<time_taken>\\S+)\\s(?<requested_ip>\\S+),(.*)",
        "(?<date>\\S+)\\s(?<time>\\S+)\\s(?<server_ip>\\S+)\\s(?<http_method>\\S+)\\s(?<url>\\S+)\\s(?<cs_uri_query>\\S+)\\s(?<port>\\S+)\\s(?<user>\\S+)\\s(?<client_ip>\\S+)\\s(?<webclient>\\S+)\\s(?<ref_url>\\S+)\\s(?<status>\\S+)\\s(?<sc_substatus>\\S+)\\s(?<sc_win32_status>\\S+)\\s(?<time_taken>\\S+)\\s(?<requested_ip>\\S)"
      ]
    },
    {
      "type": "delete",
      "fields": [
        "line_text"
      ]
    },
    {
      "type": "change_index",
      "index": "webserver"
    }
  ]
},
{
  "version": 1,
  "name": "webserver_change_index",
  "rules": [
    {
      "type": "change_index",
      "index": "webserver"
    }
  ]
},
{
  "version": 1,
  "name": "webserver_new",
  "rules": [
    {
      "type": "branch",
      "condition": "(host.name=='pgppoprddc2' or host.name=='pgppoprddc1')",
      "ifTrue": [
        {
          "type": "regex",
          "src": "line_text",
          "exp": "\\[(?<timestamp>.*?)\\]\\s+-\\s+(?<ip>\\S+)\\s+:\\s+(?<http_method>\\w+)\\s+(?<request>\\S+)\\s+(?<protocol>HTTP\\/\\d\\.\\d)\\s+(?<status>\\d{3})\\s+(?<size>\\d+)\\s+\\[(?<requested_ip>\\d+)\\]"
        },
        {
          "type": "render",
          "template": "erp_webserver",
          "dest": "sub_index"
        },
        {
          "type": "delete",
          "fields": [
            "line_text"
          ]
        }
      ]
    }
  ]
},
{
  "version": 1,
  "name": "webserver_new1",
  "rules": [
    {
      "type": "branch",
      "condition": "(host.name=='pgvepprda01' or host.name=='pgvepprda02' or host.name=='pgvepprda04' or host.name=='pgvepprda03' or host.name=='pgpsrmjprddc2' or host.name=='pgpepprddc2')",
      "ifTrue": [
        {
          "type": "regex",
          "exp": "\\[(?<date>[A-Za-z]{3}\\s+\\d{1,2},\\s+\\d{4})\\s+(?<time>\\d{1,2}:\\d{2}:\\d{2}\\s+[AP]M)\\s+]\\s*-\\s*(?<requested_ip>\\d{1,3}(?:\\.\\d{1,3}){3})\\s*:\\s*(?<http_method>[A-Z]+)\\s+(?<url>\\S+)\\s+(?<http_version>[^\"]+)\\s+(?<status>\\d{3})\\s+(?<size>\\d+)\\s+\\[(?<extra>\\d+)\\]",
          "src": "line_text"
        },
        {
          "type": "delete",
          "fields": [
            "line_text"
          ]
        }
      ]
    }
  ]
},
{
  "version": 1,
  "name": "webserver_new2",
